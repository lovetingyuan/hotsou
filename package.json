{
  "name": "hotsou-monorepo",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "app",
    "server"
  ],
  "scripts": {
    "app:start": "npm run start -w hotsou",
    "android": "npm run android -w hotsou",
    "update": "npm run update:android -w hotsou",
    "upgrade": "npm run upgrade-expo -w hotsou",
    "typegen": "npm run cf-typegen -w hotsou-server",
    "doctor": "npm run doctor -w hotsou",
    "app:check-unused": "npm run check-unused -w hotsou",
    "build": "npm run build:android -w hotsou",
    "build:preview": "npm run build:preview -w hotsou",
    "server": "npm run dev -w hotsou-server",
    "deploy": "npm run deploy -w hotsou-server",
    "lint": "npm run lint --workspaces --if-present && npm run format",
    "type-check": "npm run type-check --workspaces"
  },
  "devDependencies": {
    "eslint-plugin-expo": "^1.0.0",
    "eslint-plugin-react-compiler": "^19.1.0-rc.2",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "oxfmt": "^0.24.0",
    "oxlint": "^1.51.0",
    "typescript": "~5.9.2"
  },
  "overrides": {
    "react-native-reanimated": "4.2.1",
    "react-native-worklets": "0.7.4"
  }
}
